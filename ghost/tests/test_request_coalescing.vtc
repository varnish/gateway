varnishtest "ghost: VarnishCachePolicy.request_coalescing controls req.hash_ignore_busy"

# Two concurrent requests hit the same hash. We size the backend delay
# (200ms) to generously cover the 50ms head start between c1 and c2,
# so the second client always reaches lookup while the first is still
# fetching. With coalescing on (default) the second request waits on
# the busy object and is served from cache; with coalescing off, ghost
# writes hash_ignore_busy on req and the second request fetches too.
#
# Scenarios expect 3 total backend connections:
#  - /no-coalesce: 2 fetches (collapsed forwarding disabled)
#  - /coalesce:    1 fetch  (collapsed forwarding enabled, second waits)
server s1 -repeat 3 {
    rxreq
    delay 0.2
    txresp -body "served"
} -start

shell {
    cat > ${tmpdir}/ghost.json <<EOF
{
    "version": 2,
    "vhosts": {
        "app.example.com": {
            "routes": [
                {
                    "path_match": {"type": "Exact", "value": "/no-coalesce"},
                    "backend_groups": [
                        {"weight": 100, "backends": [
                            {"address": "${s1_addr}", "port": ${s1_port}}
                        ]}
                    ],
                    "priority": 200,
                    "cache_policy": {
                        "default_ttl_seconds": 60,
                        "request_coalescing": false
                    }
                },
                {
                    "path_match": {"type": "Exact", "value": "/coalesce"},
                    "backend_groups": [
                        {"weight": 100, "backends": [
                            {"address": "${s1_addr}", "port": ${s1_port}}
                        ]}
                    ],
                    "priority": 200,
                    "cache_policy": {
                        "default_ttl_seconds": 60,
                        "request_coalescing": true
                    }
                }
            ]
        }
    }
}
EOF
}

varnish v1 -arg "-p thread_pool_stack=160k" -vcl {
    import ghost from "${vmod}";

    backend dummy none;

    sub vcl_init {
        ghost.init("${tmpdir}/ghost.json");
        new router = ghost.ghost_backend();
    }

    sub vcl_recv {
        if (req.url == "/.varnish-ghost/reload") {
            if (router.reload()) {
                return (synth(200, "OK"));
            } else {
                return (synth(500, "Reload failed"));
            }
        }
        set req.backend_hint = router.recv();
    }
} -start

client c_reload {
    txreq -url "/.varnish-ghost/reload"
    rxresp
    expect resp.status == 200
} -run

# --- Scenario 1: request_coalescing=false → both requests fetch independently ---

client c1 {
    txreq -url "/no-coalesce" -hdr "Host: app.example.com"
    rxresp
    expect resp.status == 200
    expect resp.body == "served"
} -start

client c2 {
    delay 0.05
    txreq -url "/no-coalesce" -hdr "Host: app.example.com"
    rxresp
    expect resp.status == 200
    expect resp.body == "served"
} -start

client c1 -wait
client c2 -wait

# Both clients went through vcl_miss because hash_ignore_busy was set.
varnish v1 -expect MAIN.cache_miss == 2

# --- Scenario 2: request_coalescing=true → second request coalesces onto first ---

client c3 {
    txreq -url "/coalesce" -hdr "Host: app.example.com"
    rxresp
    expect resp.status == 200
    expect resp.body == "served"
} -start

client c4 {
    delay 0.05
    txreq -url "/coalesce" -hdr "Host: app.example.com"
    rxresp
    expect resp.status == 200
    expect resp.body == "served"
} -start

client c3 -wait
client c4 -wait

# c3 missed and fetched; c4 waited on c3's busy object and was served
# from the just-cached response → only one new miss (3 total).
varnish v1 -expect MAIN.cache_miss == 3
