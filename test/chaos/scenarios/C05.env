# C05 parameters.
# Script: 5s pre + 60s partition + ~30s converge = ~95s.
DURATION=4m
PRE_FAULT_S=15
POST_FAULT_S=15

PARTITION_S=60
PARTITION_CONVERGE_S=30
GATEWAY_NAMESPACE=varnish-load
GATEWAY_NAME=load
ROUTE_NAMESPACE=varnish-load

# Pass criteria.
# Partition affects the control plane, not the data path — existing
# routes in ghost.json stay active. Thresholds are tight.
MAX_DROP_RATIO=0.0
MAX_CONVERGE_MS=5000
MAX_MISROUTES=0
