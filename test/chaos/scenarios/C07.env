# C07 parameters.
# Requires TLS fixture — exits SKIP otherwise (see script).
DURATION=3m
PRE_FAULT_S=15
POST_FAULT_S=30

CERT_NAME=load-tls
ROTATE_SETTLE_S=30
GATEWAY_NAMESPACE=varnish-load

# Pass criteria.
# Hot-reload of certs should not drop any requests.
MAX_DROP_RATIO=0.0
MAX_CONVERGE_MS=5000
MAX_MISROUTES=0
