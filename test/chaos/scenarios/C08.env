# C08 parameters.
DURATION=3m
PRE_FAULT_S=10
POST_FAULT_S=15

SIMUL_CYCLES=10
SIMUL_SETTLE_S=20
GATEWAY_NAME=load
GATEWAY_NAMESPACE=varnish-load
ROUTE_NAMESPACE=varnish-load

# Pass criteria.
# Data path unaffected; zero tolerance for misroutes. drop_ratio
# at 1e-5 is a ledger ingest noise floor, not a real-drop tolerance.
MAX_DROP_RATIO=0.00001
MAX_CONVERGE_MS=5000
MAX_MISROUTES=0
