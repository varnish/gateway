# C09-soak parameters. See test/chaos/soak.sh.
#
# Default 3 hours — enough to surface medium-rate leaks (1 goroutine per
# ~1000 events) without burning a full weekend on the cluster. Push to 24h
# before major releases if the budget allows; 72h gives mostly the same
# answer as 24h for leaks.

# Defaults below use `:=` so that values set in the caller's environment
# (e.g. `SOAK_HOURS=1 ./test/chaos/soak.sh`) take precedence over the
# values in this file. Plain `K=V` would clobber the caller's choice.
: "${SOAK_HOURS:=3}"               # 3h default; 24h before releases
: "${SNAPSHOT_INTERVAL_S:=300}"    # 5-minute snapshots → 36 samples over 3h
: "${CHURN_INTERVAL_S:=60}"        # one apply+delete cycle per minute
: "${CHURN_ROUTES:=20}"            # 20 routes per cycle → 2400 reconciles/h
: "${SOAK_RPS:=20}"                # light k6 traffic for correctness spot-checks

# Thresholds are slopes fit through the snapshot series. Units are
# "metric delta per minute". Calibrate from a clean baseline run.
# Commented out until baseline numbers are known — unset vars skip the check.
#
# An operator/chaperone restart mid-soak (process_start_time changes)
# always fails the run regardless of these thresholds — slopes through a
# level-shifted series are meaningless.

# Memory / leak indicators
# MAX_OP_GOROUTINE_SLOPE_PER_MIN=0.5    # +30 goroutines/h sustained → leak
# MAX_OP_HEAP_SLOPE_PER_MIN=100000      # Go heap, less RSS noise (100KB/min)
# MAX_OP_RSS_SLOPE_PER_MIN=200000       # 200KB/min = 12MB/h; expected flat-ish
# MAX_OP_FDS_SLOPE_PER_MIN=0.02         # any positive trend on fds is suspect
# MAX_CH_GOROUTINE_SLOPE_PER_MIN=0.5
# MAX_CH_HEAP_SLOPE_PER_MIN=100000
# MAX_CH_FDS_SLOPE_PER_MIN=0.02
# MAX_CH_RSS_SLOPE_PER_MIN=200000

# Reconcile health
# MAX_OP_WORKQUEUE_DEPTH_SLOPE_PER_MIN=0.1  # queue should drain, not climb
# MAX_OP_RECONCILE_ERROR_RATE_PER_MIN=0     # any sustained error rate is bad
# MAX_OP_RECONCILE_RATE_TREND=0.5           # d/dt of reconciles/min — catches "more often over time"
# MAX_OP_RECONCILE_AVG_MS_TREND=1.0         # d/dt of mean ms — catches "slower over time"
# MAX_CH_GHOST_RELOAD_ERROR_RATE_PER_MIN=0

# Targeting — leave unset to pick up defaults from lib/common.sh.
# OPERATOR_NS=varnish-gateway-system
# OPERATOR_SELECTOR=app.kubernetes.io/component=operator
# CHAOS_NS=varnish-load
# GATEWAY_NAME=load
