# C09-soak parameters. See test/chaos/soak.sh.
#
# Default 3 hours — enough to surface medium-rate leaks (1 goroutine per
# ~1000 events) without burning a full weekend on the cluster. Push to 24h
# before major releases if the budget allows; 72h gives mostly the same
# answer as 24h for leaks.

# Defaults below use `:=` so that values set in the caller's environment
# (e.g. `SOAK_HOURS=1 ./test/chaos/soak.sh`) take precedence over the
# values in this file. Plain `K=V` would clobber the caller's choice.
: "${SOAK_HOURS:=3}"               # 3h default; 24h before releases
: "${SNAPSHOT_INTERVAL_S:=300}"    # 5-minute snapshots → 36 samples over 3h
: "${CHURN_INTERVAL_S:=60}"        # one apply+delete cycle per minute
: "${CHURN_ROUTES:=20}"            # 20 routes per cycle → 2400 reconciles/h
: "${SOAK_RPS:=20}"                # light k6 traffic for correctness spot-checks

# Thresholds are slopes fit through the snapshot series. Units are
# "metric delta per minute". Unset variables skip the check.
#
# An operator/chaperone restart mid-soak (process_start_time changes)
# always fails the run regardless of these thresholds — slopes through a
# level-shifted series are meaningless.
#
# Proposed values below derive from a partial 20h baseline against a
# 15-node DigitalOcean cluster (3 chaperone replicas, default churn).
# They are 3× the observed slopes as headroom — calibrate per cluster.
# Refresh once the full 24h run lands.
#
# 20h-baseline observations (see commit history for the run summary):
#   op_goroutines        slope ≈ 0,         r² ≈ 0
#   op_heap_inuse        slope ≈ -176/min,  r² ≈ 0      (noise)
#   op_rss_bytes         slope ≈ +1247/min, r² ≈ 0.47   (real, GC scavenger)
#   op_open_fds          slope ≈ 0,         r² ≈ 0
#   op_workqueue_depth   slope ≈ 0,         r² ≈ 0
#   op_reconcile_rate_trend    ≈ 0,         r² ≈ 0      (cadence flat)
#   op_reconcile_avg_ms_trend  ≈ 0,         r² ≈ 0.02   (~13.5 ms steady)
#   op_reconcile_errors_rate ≈ +0.0001/min, end ≈ 2.2/min  (steady, not growing)
#   ch_goroutines        slope ≈ 0,         r² ≈ 0
#   ch_heap_inuse        slope ≈ +187/min,  r² ≈ 0      (noise)
#   ch_rss_bytes         slope ≈ +381/min,  r² ≈ 0.33

# Memory / leak indicators
# MAX_OP_GOROUTINE_SLOPE_PER_MIN=0.05
# MAX_OP_HEAP_SLOPE_PER_MIN=10000           # 10 KB/min; observed noise ±200
# MAX_OP_RSS_SLOPE_PER_MIN=4000             # 3× observed +1250 KB/min
# MAX_OP_FDS_SLOPE_PER_MIN=0.01             # any positive trend on fds is suspect
# MAX_CH_GOROUTINE_SLOPE_PER_MIN=0.05
# MAX_CH_HEAP_SLOPE_PER_MIN=10000
# MAX_CH_FDS_SLOPE_PER_MIN=0.01
# MAX_CH_RSS_SLOPE_PER_MIN=1500             # 3× observed +380 KB/min

# Reconcile health
# MAX_OP_WORKQUEUE_DEPTH_SLOPE_PER_MIN=0.01 # queue should drain, not climb
# MAX_OP_RECONCILE_ERROR_RATE_PER_MIN=0.01  # rate stays flat; slope of rate ≈ 0
# MAX_OP_RECONCILE_RATE_TREND=0.5           # d/dt of reconciles/min — catches "more often over time"
# MAX_OP_RECONCILE_AVG_MS_TREND=0.05        # d/dt of mean ms — catches "slower over time"
# MAX_CH_GHOST_RELOAD_ERROR_RATE_PER_MIN=0

# Targeting — leave unset to pick up defaults from lib/common.sh.
# OPERATOR_NS=varnish-gateway-system
# OPERATOR_SELECTOR=app.kubernetes.io/component=operator
# CHAOS_NS=varnish-load
# GATEWAY_NAME=load
