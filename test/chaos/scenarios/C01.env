# C01 parameters.
# Total k6 run time. The fault is injected after PRE_FAULT_S.
DURATION=2m
PRE_FAULT_S=20
# How long to wait after deleting the chaos CR for traffic to converge
# before we stop k6 and analyze.
POST_FAULT_S=40

# Pass criteria (enforced by run.sh via jq on analyze output).
MAX_DROP_RATIO=0.01
MAX_CONVERGE_MS=10000
MAX_MISROUTES=0
