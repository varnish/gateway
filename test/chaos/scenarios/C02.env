# C02 parameters.
# Total k6 run time — must exceed PRE_FAULT_S + script duration + POST_FAULT_S.
# Script duration ≈ 3 * SCALE_HOLD_S + SCALE_CONVERGE_S = 65s default.
DURATION=3m
PRE_FAULT_S=15
POST_FAULT_S=20

# Script parameters (consumed by C02-rapid-backend-scaling.sh).
SCALE_HOLD_S=15
SCALE_CONVERGE_S=20
SCALE_TARGET=echo-a
ECHO_NAMESPACE=varnish-load
GATEWAY_NAMESPACE=varnish-load
GATEWAY_NAME=load

# Pass criteria.
# Drops during scale-to-0 windows are expected (empty group → 500); the
# analyzer only counts 2xx-with-no-echo as drops, so 500s do not inflate
# this. Budget is generous to absorb brief transitions.
MAX_DROP_RATIO=0.05
MAX_CONVERGE_MS=15000
MAX_MISROUTES=0
