# C04 parameters.
# Script waits up to ~60s for operator rollout + 60s for reconcile
# convergence, so DURATION must comfortably exceed that.
DURATION=4m
PRE_FAULT_S=15
POST_FAULT_S=20

# Operator targeting.
OPERATOR_NAMESPACE=varnish-gateway-system
OPERATOR_SELECTOR=app.kubernetes.io/component=operator

# Gateway + route location.
ROUTE_NAMESPACE=varnish-load
GATEWAY_NAME=load
GATEWAY_NAMESPACE=varnish-load

# Pass criteria.
# Operator downtime should not affect the data path — chaperone handles
# hot-reload independently. At multi-million-sample k6 runs a small
# number of ledger ingest misses is normal; 1e-5 (10 ppm) is a
# noise floor, not a real-drop tolerance.
MAX_DROP_RATIO=0.00001
MAX_CONVERGE_MS=5000
MAX_MISROUTES=0
