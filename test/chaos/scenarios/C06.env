# C06 parameters.
# Script: up to ~60s drain + up to ~90s reschedule wait.
DURATION=5m
PRE_FAULT_S=10
POST_FAULT_S=20

DRAIN_TIMEOUT_S=60
RESCHEDULE_S=90
GATEWAY_NAMESPACE=varnish-load
GATEWAY_NAME=load

# Pass criteria.
# k6 should see brief drops during the pod's reschedule window if the
# drained node hosted the only replica. Allow a small budget; enforce
# zero misroutes.
MAX_DROP_RATIO=0.05
MAX_CONVERGE_MS=15000
MAX_MISROUTES=0
