# C03 parameters.
# Script duration ≈ 2 * CHURN_BETWEEN_S * CHURN_CYCLES + CHURN_CONVERGE_S.
# Defaults: 2 * 5 * 3 + 20 = 50s, plus a few seconds of apply/delete overhead.
DURATION=3m
PRE_FAULT_S=15
POST_FAULT_S=15

# Script parameters (consumed by C03-httproute-churn.sh).
CHURN_COUNT=50
CHURN_CYCLES=3
CHURN_BETWEEN_S=5
CHURN_CONVERGE_S=20
ROUTE_NAMESPACE=varnish-load
GATEWAY_NAME=load
GATEWAY_NAMESPACE=varnish-load

# Pass criteria.
# Zero tolerance: the existing fixture routes must keep serving during
# churn. Any drop or misroute on them signals a ConfigMap ownership
# conflict. Convergence budget covers propagation of the final delete
# through the operator + chaperone.
MAX_DROP_RATIO=0.0
MAX_CONVERGE_MS=15000
MAX_MISROUTES=0
