{
  "title": "Varnish Gateway / Operator",
  "uid": "varnish-gateway-operator",
  "tags": ["varnish-gateway"],
  "schemaVersion": 41,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "timezone": "",
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "prometheus", "current": { "text": "Prometheus", "value": "Prometheus" } },
      { "name": "namespace",  "type": "query", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "query": "label_values(controller_runtime_reconcile_total{job=~\".*varnish-gateway-operator.*\"}, namespace)", "refresh": 2, "includeAll": true, "multi": true, "current": { "text": "All", "value": "$__all" } },
      { "name": "controller", "type": "query", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "query": "label_values(controller_runtime_reconcile_total{job=~\".*varnish-gateway-operator.*\", namespace=~\"$namespace\"}, controller)", "refresh": 2, "includeAll": true, "multi": true, "current": { "text": "All", "value": "$__all" } }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Reconcile rate (5m)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "sum(rate(controller_runtime_reconcile_total{job=~\".*varnish-gateway-operator.*\", namespace=~\"$namespace\", controller=~\"$controller\"}[5m]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Reconcile errors (1h)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "sum(increase(controller_runtime_reconcile_total{job=~\".*varnish-gateway-operator.*\", namespace=~\"$namespace\", controller=~\"$controller\", result=\"error\"}[1h]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"green","value":null},{"color":"yellow","value":1},{"color":"red","value":10}]} }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Workqueue depth",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "sum(workqueue_depth{job=~\".*varnish-gateway-operator.*\", namespace=~\"$namespace\", name=~\"$controller\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": {"mode":"thresholds"}, "thresholds": {"mode":"absolute","steps":[{"color":"green","value":null},{"color":"yellow","value":10},{"color":"red","value":100}]} }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "time() - min(process_start_time_seconds{job=~\".*varnish-gateway-operator.*\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Reconcile rate per controller",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{
        "expr": "sum by (controller) (rate(controller_runtime_reconcile_total{job=~\".*varnish-gateway-operator.*\", namespace=~\"$namespace\", controller=~\"$controller\"}[1m]))",
        "refId": "A",
        "legendFormat": "{{controller}}"
      }],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Reconcile errors per controller",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{
        "expr": "sum by (controller) (rate(controller_runtime_reconcile_total{job=~\".*varnish-gateway-operator.*\", namespace=~\"$namespace\", controller=~\"$controller\", result=\"error\"}[5m]))",
        "refId": "A",
        "legendFormat": "{{controller}}"
      }],
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } }, "overrides": [] }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Reconcile latency p50 / p95 / p99",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(controller_runtime_reconcile_time_seconds_bucket{job=~\".*varnish-gateway-operator.*\", namespace=~\"$namespace\", controller=~\"$controller\"}[5m])))", "refId": "A", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(controller_runtime_reconcile_time_seconds_bucket{job=~\".*varnish-gateway-operator.*\", namespace=~\"$namespace\", controller=~\"$controller\"}[5m])))", "refId": "B", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(controller_runtime_reconcile_time_seconds_bucket{job=~\".*varnish-gateway-operator.*\", namespace=~\"$namespace\", controller=~\"$controller\"}[5m])))", "refId": "C", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Workqueue depth per controller",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{
        "expr": "workqueue_depth{job=~\".*varnish-gateway-operator.*\", namespace=~\"$namespace\", name=~\"$controller\"}",
        "refId": "A",
        "legendFormat": "{{name}}"
      }],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Workqueue adds / retries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum by (name) (rate(workqueue_adds_total{job=~\".*varnish-gateway-operator.*\", namespace=~\"$namespace\", name=~\"$controller\"}[1m]))",    "refId": "A", "legendFormat": "adds — {{name}}" },
        { "expr": "sum by (name) (rate(workqueue_retries_total{job=~\".*varnish-gateway-operator.*\", namespace=~\"$namespace\", name=~\"$controller\"}[1m]))", "refId": "B", "legendFormat": "retries — {{name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Unfinished work seconds",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{
        "expr": "workqueue_unfinished_work_seconds{job=~\".*varnish-gateway-operator.*\", namespace=~\"$namespace\", name=~\"$controller\"}",
        "refId": "A",
        "legendFormat": "{{name}}"
      }],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    }
  ]
}
